# установить
sudo apt install cgroup-tools

# создать группу
sudo cgcreate -g memory,cpu:/pdf-limit

# лимит памяти 100MB
sudo cgset -r memory.limit_in_bytes=100M pdf-limit

# лимит CPU (25%)
sudo cgset -r cpu.cfs_quota_us=25000 pdf-limit


# Source - https://stackoverflow.com/a/63385386
# Posted by Giuseppe Scrivano, modified by community. See post 'Timeline' for change history
